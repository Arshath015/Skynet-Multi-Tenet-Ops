generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  INSTRUCTOR
  STUDENT
}

enum LessonType {
  TEXT
  QUIZ
}

enum BookingStatus {
  REQUESTED
  APPROVED
  ASSIGNED
  COMPLETED
  CANCELLED
}

model Tenant {
  id        String   @id @default(uuid())
  name      String
  createdAt DateTime @default(now())

  users    User[]
  courses  Course[]
  bookings Booking[]
}

model User {
  id       String @id @default(uuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  email        String  @unique
  passwordHash String
  role         Role
  approved     Boolean @default(false)
  refreshToken String?

  createdAt DateTime @default(now())

  @@index([tenantId])
}

model Course {
  id       String @id @default(uuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  title     String
  createdAt DateTime @default(now())

  modules Module[]

  @@index([tenantId])
}

model Module {
  id       String @id @default(uuid())
  courseId String
  course   Course @relation(fields: [courseId], references: [id])

  title   String
  lessons Lesson[]

  @@index([courseId])
}

model Lesson {
  id       String @id @default(uuid())
  moduleId String
  module   Module @relation(fields: [moduleId], references: [id])

  title   String
  type    LessonType
  content String?

  questions    Question[]
  quizAttempts QuizAttempt[]

  @@index([moduleId])
}

model Booking {
  id       String @id @default(uuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  studentId    String
  instructorId String?

  startTime DateTime
  endTime   DateTime
  status    BookingStatus @default(REQUESTED)

  createdAt DateTime @default(now())

  @@index([tenantId])
  @@index([instructorId])
}

model AuditLog {
  id            String   @id @default(uuid())
  tenantId      String
  userId        String
  action        String
  entity        String
  before        Json?
  after         Json?
  correlationId String
  createdAt     DateTime @default(now())

  @@index([tenantId])
}

model Question {
  id       String @id @default(uuid())
  lessonId String
  lesson   Lesson @relation(fields: [lessonId], references: [id])

  text    String
  options Json // ["A", "B", "C", "D"]
  correct String

  @@index([lessonId])
}

model QuizAttempt {
  id       String @id @default(uuid())
  lessonId String
  lesson   Lesson @relation(fields: [lessonId], references: [id])

  studentId String
  score     Int
  answers   Json // { questionId: selectedOption }

  createdAt DateTime @default(now())

  @@index([lessonId])
  @@index([studentId])
}

model InstructorAvailability {
  id           String   @id @default(uuid())
  tenantId     String
  instructorId String
  startTime    DateTime
  endTime      DateTime
  createdAt    DateTime @default(now())

  @@index([tenantId])
  @@index([instructorId])
}